#!/bin/sh
# Zenoform pre-commit hook
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

echo "=== Zenoform Pre-Commit Checks ==="

echo "[1/4] Running cargo fmt..."
cargo fmt --all -- --check

echo "[2/4] Running cargo clippy..."
cargo clippy --all-targets -- -D warnings

echo "[3/4] Running cargo test..."
cargo test --all

echo "[4/4] Running scarb build..."
if command -v scarb &> /dev/null; then
    cd cairo/terrain_v1 && scarb build && cd ../..
else
    echo "  (scarb not found, skipping Cairo checks)"
fi

echo ""
echo "=== All pre-commit checks passed ==="
